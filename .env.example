# Frontend Environment Variables
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_GOOGLE_ANALYTICS_ID=

# Backend Environment Variables
NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://postgres:password@localhost:5432/resume_db
TYPST_SERVICE_URL=http://localhost:5050
JWT_SECRET=your-super-secret-jwt-key-change-in-production
SESSION_SECRET=your-session-secret-key-change-this-too

# Typst Service Environment Variables
TYPST_PORT=5050
MAX_COMPILE_TIME=30
CACHE_ENABLED=true
CACHE_DIR=/cache

# Database (if not using Docker)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=resume_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Security
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100  # per window per IP
API_KEY=your-api-key-for-external-calls

# Email (optional, for user registration)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@resume-generator.com